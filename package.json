{
    "name": "singha-roy-enterprise",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint --flag unstable_native_nodejs_ts_config .",
        "type-check": "pnpm run cloudflare-typegen && tsc",
        "format": "prettier --write '**/*.{ts,tsx,css,json,jsonc,yml,yaml}'",
        "format:check": "prettier --check '**/*.{ts,tsx,scss,json,jsonc,yml,yaml}'",
        "deploy:staging": "pnpm run cloudflare-typegen && opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --env staging",
        "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
        "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview -- --env staging",
        "cloudflare-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio",
        "db:migrate:local": "wrangler d1 migrations apply singha-roy-enterprise-d1 --local",
        "db:migrate:staging": "wrangler d1 migrations apply singha-roy-enterprise-staging-d1 --remote --env staging",
        "prepare": "git config core.hooksPath .githooks"
    },
    "postcss": {
        "plugins": {
            "@tailwindcss/postcss": {}
        }
    },
    "dependencies": {
        "@opennextjs/cloudflare": "^1.20.1",
        "@tanstack/react-query": "^5.101.2",
        "@trpc/client": "^11.18.0",
        "@trpc/react-query": "^11.18.0",
        "@trpc/server": "^11.18.0",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "next": "15.3.9",
        "pdfmake": "^0.3.11",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "react": "^19.1.7",
        "react-dom": "^19.1.7",
        "react-icons": "^5.6.0",
        "superjson": "^2.2.6",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20.19.43",
        "@types/pdfmake": "^0.3.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.1.7",
        "autoprefixer": "^10.5.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "postcss": "^8.5.15",
        "postcss-import": "^16.1.1",
        "postcss-load-config": "^6.0.1",
        "postcss-nesting": "^14.0.0",
        "prettier": "^3.9.1",
        "tailwindcss": "^4.3.1",
        "typescript": "^5.7.4",
        "wrangler": "^4.105.0"
    }
}
