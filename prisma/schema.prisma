// Prisma schema for Singha Roy Enterprise.
//
// Runtime target is Cloudflare D1 (serverless SQLite) accessed through the
// `@prisma/adapter-d1` driver adapter — no Rust query engine is shipped. The
// datasource `url` below is only used by the Prisma CLI (migrate diff / studio);
// at runtime the D1 binding is supplied via the adapter in `src/server/db.ts`.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// An authenticated account. Passwords are stored as PBKDF2 hashes
/// (see `src/server/auth/password.ts`), never in plain text.
model User {
  id        String    @id @default(cuid())
  username  String    @unique
  email     String    @unique
  name      String
  initials  String
  /// "admin" | "user" — guests are unauthenticated and have no row.
  role      String    @default("user")
  /// Encoded as `pbkdf2$<iterations>$<saltB64>$<hashB64>`.
  password  String
  createdAt DateTime  @default(now())
  sessions  Session[]

  @@map("users")
}

/// A server-side session, referenced by an opaque token held in an httpOnly cookie.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

/// A stock-ledger line. `qty <= 0` is "out", `qty <= reorder` is "low".
model InventoryItem {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String   @default("")
  unit        String   @default("pcs")
  qty         Int      @default(0)
  purchase    Float    @default(0)
  selling     Float    @default(0)
  reorder     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inventory_items")
}
